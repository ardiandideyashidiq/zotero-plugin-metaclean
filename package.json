{
  "name": "zotero-meta-clean",
  "type": "module",
  "version": "1.1.0",
  "description": "Normalize and clean metadata (titles, journals, publishers, creators) in Zotero",
  "config": {
    "addonName": "Zotero MetaClean",
    "addonID": "metaclean@yourdomain.com",
    "addonRef": "meta-clean",
    "addonInstance": "MetaClean",
    "prefsPrefix": "extensions.zotero.meta-clean"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ardiandideyashidiq/zotero-plugin-metaclean.git"
  },
  "author": "ardiandideyashidiq",
  "bugs": {
    "url": "https://github.com/ardiandideyashidiq/zotero-plugin-metaclean/issues"
  },
  "homepage": "https://github.com/ardiandideyashidiq/zotero-plugin-metaclean",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.4"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.1",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "typescript": "^6.0.3",
    "zotero-plugin-scaffold": "^0.8.6",
    "zotero-types": "^4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
